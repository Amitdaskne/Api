rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny safety safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Rules for User Profile collection
    match /users/{userId} {
      // Users can get/read their own profile records
      allow get, read: if isOwner(userId);
      
      // Strict creation blueprint verification
      allow create: if isOwner(userId) 
        && isEmailVerified()
        && request.resource.data.balance == 50
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.name is string && request.resource.data.name.size() <= 100
        && request.resource.data.upiId is string && request.resource.data.upiId.size() <= 100;

      // Allow updating profile (like active bank indices or updating balances securely)
      allow update: if isOwner(userId)
        && isEmailVerified()
        && request.resource.data.email == existing().email
        && request.resource.data.balance is number
        && request.resource.data.balance >= 0;

      // Disallow absolute profile deletions to guard record indices
      allow delete: if false;
    }

    // Rules for Transaction collection (Immutable logs)
    match /transactions/{transactionId} {
      // Must be owner of the transaction log
      allow get, read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Allow creating transactions if you are the verified sender
      allow create: if isSignedIn()
        && isEmailVerified()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.status == 'SUCCESS';

      // Transactions are read-only ledger logs, absolutely immutable subsequent to create
      allow update, delete: if false;
    }
  }
}
